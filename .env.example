# ==============================================================================
# Environment Variables Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# Application Base Settings
# ------------------------------------------------------------------------------
# Provider configurations (e.g., auth0, mock, supabase)
NEXT_PUBLIC_AUTH_PROVIDER=auth0
NEXT_PUBLIC_DB_PROVIDER=mock # Set to 'supabase' to use the real database

# Base URL of the application
APP_BASE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Supabase Configuration
# ------------------------------------------------------------------------------
# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Your Supabase anon/publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
# Your Supabase service role key or RPC secret (for secure backend operations)
SUPABASE_RPC_SECRET=your_supabase_service_role_key

# ------------------------------------------------------------------------------
# Auth0 Configuration (Authentication)
# ------------------------------------------------------------------------------
# A long, secret value used to encrypt the session cookie (Run: `openssl rand -hex 32`)
AUTH0_SECRET=your_generated_32_byte_secret
# Your Auth0 tenant domain
AUTH0_DOMAIN=your_auth0_tenant.us.auth0.com
# Your Auth0 application client ID
AUTH0_CLIENT_ID=your_auth0_client_id
# Your Auth0 application client secret
AUTH0_CLIENT_SECRET=your_auth0_client_secret
