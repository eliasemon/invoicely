# ==============================================================================
# Environment Variables Configuration (Example)
# ==============================================================================

# ------------------------------------------------------------------------------
# Application Base Settings
# ------------------------------------------------------------------------------
# Auth provider configuration ('mock' or 'supabase')
NEXT_PUBLIC_AUTH_PROVIDER=supabase

# Client-side DB provider configuration ('mock')
# Note: The server-side actions query Supabase directly; this controls context initialization.
NEXT_PUBLIC_DB_PROVIDER=mock

# Base URLs of the application
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Supabase Configuration
# ------------------------------------------------------------------------------
# Your Supabase project URL (e.g. https://your-project-ref.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Secret token used for custom API/RPC verification (must match the check_api_secret trigger config)
SUPABASE_RPC_SECRET=your_supabase_rpc_secret
